{
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.format.settings.url": "./.vscode/java-formatter.xml",
    "java.format.settings.profile": "MyWeiboFormatter",
    "files.encoding": "utf8",
    "terminal.integrated.defaultProfile.windows": "PowerShell 7 UTF-8",
    "terminal.integrated.profiles.windows": {
        "PowerShell 7 UTF-8": {
            "path": "pwsh.exe",
            "args": [
                "-NoLogo",
                "-NoExit",
                "-Command",
                "chcp.com 65001 | Out-Null; [Console]::InputEncoding = [System.Text.Encoding]::UTF8; [Console]::OutputEncoding = [System.Text.Encoding]::UTF8"
            ]
        }
    }
}
